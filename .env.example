# ─────────────────────────────────────────────────────────────
# Video Editor Mini App — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────

# ── Storage (MinIO locally / S3 in production) ───────────────
# Local: http://minio:9000
# Production: https://s3.amazonaws.com  (or regional endpoint)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET=video-editor-storage

# AWS credentials (use minioadmin/minioadmin for local MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# How long pre-signed download URLs are valid (seconds)
PRESIGNED_URL_EXPIRY_SECONDS=900

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Worker ───────────────────────────────────────────────────
WORKER_URL=http://worker:8000

# Max download size for yt-dlp (megabytes)
MAX_FILESIZE_MB=500

# Max source video length (seconds) — 900 = 15 minutes
MAX_VIDEO_SECONDS=900

# ── Queue limits ─────────────────────────────────────────────
# Max simultaneous FFmpeg jobs (keep 1 for 0.5 vCPU constraint)
MAX_CONCURRENT_JOBS=1

# Return HTTP 429 when waiting queue depth exceeds this
QUEUE_MAX_DEPTH=10

# ── Backend ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
